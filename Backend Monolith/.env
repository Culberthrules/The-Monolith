# ── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Client Configuration ──────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── JWT Configuration ────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a strong, random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_change_this_in_production_12345
JWT_EXPIRES_IN=7d

# ── Firebase Configuration ──────────────────────────────────────────────────
# (Optional - Firebase credentials are loaded from serviceaccountkey.json)
# FIREBASE_PROJECT_ID is read from the service account key file

# ── CORS & Security ─────────────────────────────────────────────────────────
# CORS is configured in src/components/app.js
# Adjust if needed for production
